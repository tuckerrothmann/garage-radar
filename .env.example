# ============================================================
# Garage Radar — Environment Variables
# Copy to .env and fill in values.
# .env is gitignored — never commit real secrets.
# ============================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=garage_radar
POSTGRES_PORT=5432
# Full async URL used by the app (auto-set in docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/garage_radar

# --- Raw snapshot store ---
# Local path (dev) or S3-compatible bucket (prod)
SNAPSHOT_STORE_PATH=./data/snapshots
SNAPSHOT_STORE_BACKEND=local   # or: s3
# S3_BUCKET=garage-radar-snapshots
# S3_ENDPOINT_URL=https://...    # Leave blank for AWS; set for Backblaze/Cloudflare R2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- eBay API ---
# Register at https://developer.ebay.com → get a production App ID
EBAY_APP_ID=

# --- Vehicle targets ---
# Leave VEHICLE_TARGET_PRESET empty to use the single target below, or set it
# to `major_makes` to crawl a broad multi-make watchlist.
VEHICLE_TARGET_PRESET=major_makes
# Optional JSON override for a fully custom watchlist. Takes precedence over
# VEHICLE_TARGET_PRESET and the single-target fallback below.
VEHICLE_TARGETS_JSON=

# Single-target fallback used when VEHICLE_TARGET_PRESET and
# VEHICLE_TARGETS_JSON are both blank.
VEHICLE_TARGET_MAKE=Porsche
VEHICLE_TARGET_MODEL=911
VEHICLE_TARGET_KEYWORDS=
VEHICLE_TARGET_YEAR_MIN=1965
VEHICLE_TARGET_YEAR_MAX=1998

# --- Reference profile enrichment ---
# Used for cached "more info" profile lookups via Wikimedia APIs
REFERENCE_CACHE_PATH=./data/reference_cache
REFERENCE_CACHE_TTL_HOURS=168
REFERENCE_MISS_CACHE_TTL_HOURS=12
REFERENCE_REQUEST_TIMEOUT_S=20
REFERENCE_PROFILE_BUDGET_S=8
# Wikimedia rejects vague bots; include an app name plus a URL or contact
REFERENCE_USER_AGENT=GarageRadar/0.1 (https://github.com/tuckerrothmann/garage-radar)

# --- Alerting: Email (SendGrid) ---
SENDGRID_API_KEY=
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=alerts@garage-radar.local

# --- Alerting: Slack ---
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- App behavior ---
LOG_LEVEL=INFO
# Set to "1" to prevent the scheduler from starting inside the API process
# DISABLE_SCHEDULER=1

# Crawler rate limits (requests per second; floats)
BAT_RATE_LIMIT=0.33
CARSANDBIDS_RATE_LIMIT=0.25
PCARMARKET_RATE_LIMIT=0.17

# --- Insight engine thresholds ---
UNDERPRICED_ALERT_THRESHOLD=-0.15   # -15% vs cluster median
PRICE_DROP_ALERT_THRESHOLD=0.05     # 5% drop since last scrape
COMP_CLUSTER_MIN_SIZE=5             # Minimum comps to compute a price band
COMP_WINDOW_DAYS=90                 # Default rolling window for comp clusters
COMP_WINDOW_THIN_DAYS=180           # Extended window for thin clusters

# --- Ports (docker-compose only) ---
API_PORT=8000
FRONTEND_PORT=3000

# --- Frontend ---
# Set this in the frontend environment if the API is not on localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Docker build/runtime value used by the frontend container
FRONTEND_DOCKER_API_URL=http://api:8000
# Browser-facing API URL baked into the frontend client bundle
FRONTEND_BROWSER_API_URL=http://localhost:8000
