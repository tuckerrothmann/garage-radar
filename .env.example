# ============================================================
# Garage Radar — Environment Variables
# Copy to .env and fill in values.
# .env is gitignored — never commit real secrets.
# ============================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=garage_radar
POSTGRES_PORT=5432
# Full async URL used by the app (auto-set in docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/garage_radar

# --- Raw snapshot store ---
# Local path (dev) or S3-compatible bucket (prod)
SNAPSHOT_STORE_PATH=./data/snapshots
SNAPSHOT_STORE_BACKEND=local   # or: s3
# S3_BUCKET=garage-radar-snapshots
# S3_ENDPOINT_URL=https://...    # Leave blank for AWS; set for Backblaze/Cloudflare R2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- eBay API ---
# Register at https://developer.ebay.com → get a production App ID
EBAY_APP_ID=

# --- Alerting: Email (SendGrid) ---
SENDGRID_API_KEY=
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=alerts@garage-radar.local

# --- Alerting: Slack ---
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- App behavior ---
LOG_LEVEL=INFO
# Set to "1" to prevent the scheduler from starting inside the API process
# DISABLE_SCHEDULER=1

# Crawler rate limits (requests per second; floats)
BAT_RATE_LIMIT=0.33
CARSANDBIDS_RATE_LIMIT=0.25
PCARMARKET_RATE_LIMIT=0.17

# --- Insight engine thresholds ---
UNDERPRICED_ALERT_THRESHOLD=-0.15   # -15% vs cluster median
UNDERPRICED_MIN_DOLLAR=2000         # Minimum $ gap vs median to alert (prevents noise on cheap cars)
PRICE_DROP_ALERT_THRESHOLD=0.05     # 5% drop (single-period or cumulative)
PRICE_DROP_MIN_DOLLAR=1500          # Minimum $ drop to alert (prevents noise on cheap cars)
COMP_CLUSTER_MIN_SIZE=5             # Minimum comps to compute a price band
COMP_WINDOW_DAYS=90                 # Default rolling window for comp clusters
COMP_WINDOW_THIN_DAYS=180           # Extended window for thin clusters

# --- Ports (docker-compose only) ---
API_PORT=8000
FRONTEND_PORT=3000

# --- Frontend build ---
# Public-facing URL of the backend API — must be reachable from the browser.
# Used as a Docker build arg (baked into the JS bundle at build time).
# For local Docker: http://localhost:8000 (default)
# For remote deployments: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
